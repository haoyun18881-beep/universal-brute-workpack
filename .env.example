# Universal Brute Workpack environment template.
# Copy to .env for local development, or set these variables in your MCP client.

# Optional web search providers. If unset, search.web falls back to DuckDuckGo instant answer.
TAVILY_API_KEY=
EXA_API_KEY=

# Optional external memory/vector service. If unset, memory.search falls back to local text search.
UBW_MEMORY_URL=

# Optional OpenAI-compatible model backend for agent.spawn / agent.pipeline.
# Example: https://api.openai.com/v1 or another compatible provider base URL.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional runtime controls.
UBW_CONFIG=
UBW_PROFILES=
UBW_PROFILE=admin
UBW_ROOTS=*
UBW_SIDECAR_MODE=managed
UBW_SIDECAR_PORT=0
UBW_SIDECAR_STARTUP_TIMEOUT_MS=15000
UBW_WORKER_POOL_ENABLED=1
UBW_WORKER_POOL_SIZE=
UBW_WORKER_MIN_PARALLEL_FILES=1
UBW_WORKER_MAX_FILE_BYTES=2000000

# Optional pipeline controls.
UBW_SIDECAR_URL=
UBW_AGENT_MAX_PIPELINE_TASKS=100
UBW_AGENT_CONCURRENCY=20
UBW_AGENT_STAGGER_MS=0
UBW_AGENT_TASK_TIMEOUT_MS=300000
UBW_AGENT_TASK_HISTORY_LIMIT=1000
UBW_MEMORY_TIMEOUT_MS=15000
UBW_MEMORY_MAX_LOCAL_FILES=3000
UBW_MEMORY_MAX_FILE_BYTES=2000000
