# Example environment for a public HTTPS Streamable HTTP deployment.
# Copy into your hosting provider's environment settings; do not commit real keys.

UBW_TRANSPORT=streamable-http
UBW_HOST=0.0.0.0
UBW_PORT=18890
UBW_PROFILE=readonly

# Use a narrow, existing directory in the hosted container for file tools.
# Avoid "*" on public endpoints.
UBW_ROOTS=/tmp/ubw-public-root

# Add the exact web origins that may call this HTTP server with an Origin header.
# Separate multiple origins with semicolons.
UBW_ALLOWED_ORIGINS=https://smithery.ai

# Optional: enable stronger search or Agent tools with provider env vars.
# Keep these empty in shared examples.
EXA_API_KEY=
TAVILY_API_KEY=
UBW_MEMORY_URL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
