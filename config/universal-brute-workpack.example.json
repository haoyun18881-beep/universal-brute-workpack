{
  "server": {
    "host": "127.0.0.1",
    "port": 18890
  },
  "profile": "admin",
  "transport": "stdio",
  "roots": [
    "*"
  ],
  "search": {
    "backends": [
      "exa",
      "tavily",
      "duckduckgo"
    ],
    "providers": {
      "exa": {
        "endpoint": "https://api.exa.ai/search",
        "apiKey": "",
        "apiKeyEnv": "EXA_API_KEY"
      },
      "tavily": {
        "endpoint": "https://api.tavily.com/search",
        "apiKey": "",
        "apiKeyEnv": "TAVILY_API_KEY"
      },
      "duckduckgo": {
        "endpoint": "https://api.duckduckgo.com/"
      }
    },
    "maxResults": 5,
    "timeoutMs": 15000
  },
  "sidecar": {
    "mode": "managed",
    "url": "",
    "port": 0,
    "startupTimeoutMs": 15000
  },
  "worker": {
    "enabled": true,
    "poolSize": 0,
    "minParallelFiles": 1,
    "maxFileBytes": 2000000
  },
  "memory": {
    "url": "",
    "urlEnv": "UBW_MEMORY_URL",
    "timeoutMs": 15000,
    "maxLocalFiles": 3000,
    "maxFileBytes": 2000000
  },
  "llm": {
    "baseUrl": "",
    "baseUrlEnv": "LLM_BASE_URL",
    "apiKey": "",
    "apiKeyEnv": "LLM_API_KEY",
    "model": "",
    "modelEnv": "LLM_MODEL",
    "timeoutMs": 300000,
    "temperature": 0.2
  },
  "agent": {
    "maxPipelineTasks": 100,
    "concurrency": 20,
    "staggerMs": 0,
    "taskTimeoutMs": 300000,
    "taskHistoryLimit": 1000
  },
  "limits": {
    "maxOutputChars": 60000,
    "maxFetchChars": 80000,
    "commandTimeoutMs": 10000
  }
}
